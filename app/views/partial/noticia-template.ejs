<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/noticia-artigo.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
</head>
<body>
  <header class="main-header desktop-header">
    <section class="header-container">
      <article class="brand-wrapper">
        <a href="/" class="brand-link" aria-label="Página inicial">
          <img src="/images/logotipo.png" alt="Logotipo Hydria" class="logo-img">
          <span class="brand-text">HYDRIA</span>
        </a>
      </article>

      <nav class="main-navigation" aria-label="Navegação principal">
        <ul>
          <li><a href="/projetos">PROJETOS</a></li>
          <li><a href="/sobre">SOBRE</a></li>
          <li><a href="/contato">CONTATO</a></li>
        </ul>
      </nav>

      <aside class="actions-wrapper">
        <nav class="accessibility-controls" aria-label="Controles de acessibilidade">
          <button type="button" id="decrease-font" aria-label="Diminuir tamanho do texto">
            <img src="/images/A-acessibilidade.png" alt="Ícone diminuir fonte">
          </button>
          <button type="button" id="increase-font" aria-label="Aumentar tamanho do texto">
            <img src="/images/A+acessibilidade.png" alt="Ícone aumentar fonte">
          </button>
          <button type="button" id="toggle-contrast" aria-label="Alternar alto contraste">
            <img src="/images/contrasteacessibilidade.png" alt="Ícone alto contraste">
          </button>
        </nav>

        <nav class="auth-navigation" aria-label="Autenticação de usuário">
          <a href="/auth/login" class="btn-login">LOGIN</a>
          <a href="/auth/cadastro" class="btn-cadastro">CADASTRO</a>
        </nav>
      </aside>
    </section>
  </header>

  <main class="noticia-page-container">
    <article class="main-news-article">
      <header>
        <h1><%= newsTitle %></h1>
        <figure class="featured-image-container">
          <img src="<%= featuredImage %>" alt="<%= featuredAlt %>">
        </figure>
      </header>

      <section class="article-content">
        <% articleParagraphs.forEach(function(paragraph) { %>
          <p><%= paragraph %></p>
        <% }); %>
      </section>

      <p class="source-info"><strong>Fonte:</strong> <%= sourceValue %></p>
    </article>

    <hr class="section-divider">

    <section class="more-news-section">
      <header>
        <h2>MAIS NOTÍCIAS</h2>
      </header>

      <ul class="news-cards-grid">
        <% relatedNews.forEach(function(newsItem) { %>
          <li>
            <a href="<%= newsItem.href %>" class="mini-news-link" aria-label="Abrir notícia: <%= newsItem.title %>">
              <article class="mini-news-card">
                <figure>
                  <img src="<%= newsItem.image %>" alt="<%= newsItem.alt %>">
                </figure>
                <h3><%= newsItem.title %></h3>
                <p class="mini-news-excerpt"><%= newsItem.excerpt %></p>
              </article>
            </a>
          </li>
        <% }); %>
      </ul>
    </section>
  </main>

  <nav class="mobile-navigation" aria-label="Navegação inferior">
    <ul>
      <li><a href="/" class="active"><i class="fas fa-home" aria-hidden="true"></i><span>Início</span></a></li>
      <li><a href="/projetos"><i class="fas fa-file-alt" aria-hidden="true"></i><span>Projetos</span></a></li>
      <li><a href="/contato"><i class="fas fa-comment-dots" aria-hidden="true"></i><span>Contato</span></a></li>
      <li><a href="/sobre"><i class="fas fa-users" aria-hidden="true"></i><span>Sobre</span></a></li>
      <li><a href="/auth/login"><i class="fas fa-user" aria-hidden="true"></i><span>Perfil</span></a></li>
    </ul>
  </nav>

  <script src="/js/auto-fix.js"></script>
  <%- include("../partial/footer") %>

