<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Selecionar Valor</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/pagamento.css">
    <link rel="stylesheet" href="/css/selecionar-valor.css">
    <script src="/js/donation-auth-gate.js"></script>
</head>
<body>

    
<header class="main-header desktop-header">
    <section class="header-container">
        <article class="brand-wrapper">
            <a href="/" class="brand-link" aria-label="Página inicial">
                <img src="/images/logotipo.png" alt="Logotipo Hydria" class="logo-img">
                <span class="brand-text">HYDRIA</span>
            </a>
        </article>

        <nav class="main-navigation" aria-label="Navegação principal">
            <ul>
                <li><a href="/projetos">PROJETOS</a></li>
                <li><a href="/sobre">SOBRE</a></li>
                <li><a href="/contato">CONTATO</a></li>
            </ul>
        </nav>

        <aside class="actions-wrapper">
            <nav class="accessibility-controls" aria-label="Controles de acessibilidade">
                <button type="button" id="decrease-font" aria-label="Diminuir tamanho do texto">
                    <img src="/images/A-acessibilidade.png" alt="Ícone diminuir fonte">
                </button>
                <button type="button" id="increase-font" aria-label="Aumentar tamanho do texto">
                    <img src="/images/A+acessibilidade.png" alt="Ícone aumentar fonte">
                </button>
                <button type="button" id="toggle-contrast" aria-label="Alternar alto contraste">
                    <img src="/images/contrasteacessibilidade.png" alt="Ícone alto contraste">
                </button>
            </nav>

            <nav class="auth-navigation" aria-label="Autenticação de usuário">
                <a href="/auth/login" class="btn-login">LOGIN</a>
                <a href="/auth/cadastro" class="btn-cadastro">CADASTRO</a>
            </nav>
        </aside>
    </section>
</header>
<main class="doacao-selecao selecionar-valor-page">
        <section class="pagamento-container card-container">
            <article class="form-section">
            <nav class="back-nav">
                <a href="javascript:history.back()" class="btn-voltar">
                    <i class="fa-solid fa-arrow-left"></i>
                    VOLTAR
                </a>
            </nav>

                <header class="valor-header">
                    <h1>Selecionar Valor</h1>
                </header>

                <div class="valores-grid">
                    <button type="button" class="btn-valor-card" data-amount="25">
                        <span class="valor-texto">R$ 25</span>
                    </button>

                    <button type="button" class="btn-valor-card" data-amount="50">
                        <span class="valor-texto">R$ 50</span>
                    </button>

                    <button type="button" class="btn-valor-card" data-amount="75">
                        <span class="valor-texto">R$ 75</span>
                    </button>

                    <button type="button" class="btn-valor-card" data-amount="95">
                        <span class="valor-texto">R$ 95</span>
                    </button>
                </div>

                <section class="acoes-finais">
                    <button type="button" class="btn-outro" id="btn-outro-valor">OUTRO VALOR</button>
                    <button type="button" class="btn-proximo" id="btn-proximo" disabled>PRÓXIMO</button>
                </section>

                <div class="valor-personalizado" id="valor-personalizado">
                    <label for="valor-personalizado-input">Digite o valor que deseja doar</label>
                    <input type="number" id="valor-personalizado-input" min="1" placeholder="Ex: 20">
                </div>
            </article>

            <aside class="visual-section">
                <figure class="hero-image">
                    <img src="/images/doacao.png" alt="Doação">
                    <div class="blue-blur-overlay" aria-hidden="true"></div>
                </figure>
                <figure class="shape-orange" aria-hidden="true"></figure>
            </aside>

        </section>
    </main>

    

    <nav class="mobile-navigation" aria-label="Navega��o inferior">
        <ul>
            <li>
                <a href="/">
                    <i class="fas fa-home" aria-hidden="true"></i>
                    <span>Inicio</span>
                </a>
            </li>
            <li>
                <a href="/projetos">
                    <i class="fas fa-file-alt" aria-hidden="true"></i>
                    <span>Projetos</span>
                </a>
            </li>
            <li>
                <a href="/contato">
                    <i class="fas fa-comment-dots" aria-hidden="true"></i>
                    <span>Contato</span>
                </a>
            </li>
            <li>
                <a href="/sobre">
                    <i class="fas fa-users" aria-hidden="true"></i>
                    <span>Sobre</span>
                </a>
            </li>
        </ul>
    </nav>

    <script>
        const valorCards = document.querySelectorAll('.btn-valor-card');
        const btnOutroValor = document.getElementById('btn-outro-valor');
        const valorPersonalizado = document.getElementById('valor-personalizado');
        const valorPersonalizadoInput = document.getElementById('valor-personalizado-input');
        const btnProximo = document.getElementById('btn-proximo');

        let selectedAmount = null;

        function clearSelection() {
            valorCards.forEach(card => card.classList.remove('is-selected'));
        }

        function updateProceedState() {
            btnProximo.disabled = !(Number(selectedAmount) > 0);
        }

        valorCards.forEach(card => {
            card.addEventListener('click', () => {
                clearSelection();
                card.classList.add('is-selected');
                selectedAmount = Number(card.dataset.amount);
                valorPersonalizadoInput.value = '';
                valorPersonalizado.classList.remove('is-open');
                updateProceedState();
            });
        });

        btnOutroValor.addEventListener('click', () => {
            valorPersonalizado.classList.toggle('is-open');
            clearSelection();
            selectedAmount = null;
            updateProceedState();
            if (valorPersonalizado.classList.contains('is-open')) {
                setTimeout(() => {
                    valorPersonalizadoInput.focus();
                    valorPersonalizadoInput.scrollIntoView({ behavior: 'smooth', block: 'end' });
                }, 400);
            }
        });

        valorPersonalizadoInput.addEventListener('focus', () => {
            setTimeout(() => {
                if (window.visualViewport) {
                    const viewport = window.visualViewport;
                    const inputRect = valorPersonalizadoInput.getBoundingClientRect();
                    const inputBottom = inputRect.bottom;
                    const viewportBottom = viewport.height;
                    if (inputBottom > viewportBottom - 20) {
                        const scrollBy = inputBottom - viewportBottom + 40;
                        window.scrollBy({ top: scrollBy, behavior: 'smooth' });
                    }
                } else {
                    valorPersonalizadoInput.scrollIntoView({ behavior: 'smooth', block: 'end' });
                }
            }, 400);
        });

        valorPersonalizadoInput.addEventListener('input', () => {
            const value = Number(valorPersonalizadoInput.value);
            selectedAmount = value > 0 ? value : null;
            clearSelection();
            updateProceedState();
        });

        btnProximo.addEventListener('click', () => {
            const customValue = Number(valorPersonalizadoInput.value);
            const amountToSend = Number(selectedAmount || customValue);

            if (!(amountToSend > 0)) {
                alert('Selecione um valor ou digite um valor personalizado para continuar.');
                return;
            }

            sessionStorage.setItem('donationAmount', String(amountToSend));
            window.location.href = '/pagamento';
        });

        updateProceedState();
    </script>

    <script src="/js/auto-fix.js"></script>

    <%- include("../partial/footer") %>
