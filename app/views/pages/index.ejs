    <script src="/js/auto-fix.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            function centerHighlights() {
                if (!window.matchMedia('(max-width: 768px)').matches) return;
                var container = document.querySelector('.highlights-carousel');
                if (!container) return;
                var cards = container.querySelectorAll('.ong-card');
                if (cards.length < 2) return;
                var target = cards[1]; // segundo card
                var scrollLeft = target.offsetLeft - (container.clientWidth - target.clientWidth) / 2;
                container.scrollTo({ left: scrollLeft, behavior: 'smooth' });
            }

            centerHighlights();
            var resizeTimer;
            window.addEventListener('resize', function () {
                clearTimeout(resizeTimer);
                resizeTimer = setTimeout(centerHighlights, 150);
            });
        });
    </script>

