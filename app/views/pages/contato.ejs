<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contato</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/contato.css">
</head>
<body>
    <header class="main-header desktop-header">
        <section class="header-container">
            <article class="brand-wrapper">
                <a href="/" class="brand-link" aria-label="Página inicial">
                    <img src="/images/logotipo.png" alt="Logotipo Hydria" class="logo-img">
                    <span class="brand-text">HYDRIA</span>
                </a>
            </article>

            <nav class="main-navigation" aria-label="Navegação principal">
                <ul>
                    <li><a href="/projetos">PROJETOS</a></li>
                    <li><a href="/sobre">SOBRE</a></li>
                    <li><a href="/contato">CONTATO</a></li>
                </ul>
            </nav>

            <aside class="actions-wrapper">
                <nav class="accessibility-controls" aria-label="Controles de acessibilidade">
                    <button type="button" id="decrease-font" aria-label="Diminuir tamanho do texto">
                        <img src="/images/A-acessibilidade.png" alt="Ícone diminuir fonte">
                    </button>
                    <button type="button" id="increase-font" aria-label="Aumentar tamanho do texto">
                        <img src="/images/A+acessibilidade.png" alt="Ícone aumentar fonte">
                    </button>
                    <button type="button" id="toggle-contrast" aria-label="Alternar alto contraste">
                        <img src="/images/contrasteacessibilidade.png" alt="Ícone alto contraste">
                    </button>
                </nav>

                <nav class="auth-navigation" aria-label="Autenticação de usuário">
                    <a href="/auth/login" class="btn-login">LOGIN</a>
                    <a href="/auth/cadastro" class="btn-cadastro">CADASTRO</a>
                </nav>
            </aside>
        </section>
    </header>
<main class="contato-desktop">
    <section class="contato-container">
        
        <article class="form-content">
            <nav class="back-nav">
                <a href="javascript:history.back()" class="btn-voltar">
                    <i class="fa-solid fa-arrow-left" aria-hidden="true"></i> VOLTAR
                </a>
            </nav>

            <header>
                <h1>Contate-nos</h1>
            </header>

            <form action="/mensagemEnviada/" method="GET" id="contact-form">
                <p class="field-full">
                    <label for="email">E-mail</label>
                    <input type="email" id="email" required>
                </p>

                <section class="field-row">
                    <p class="field-half">
                        <label for="telefone">Telefone</label>
                        <input type="tel" id="telefone">
        <div class="bottom-spacer" aria-hidden="true"></div>
    
        <nav class="mobile-navigation" aria-label="Navegação inferior">
                        <label for="assunto">Assunto</label>
                        <input type="text" id="assunto" required>
                    </p>
                </section>

                <p class="field-full">
                    <label for="mensagem">Mensagem</label>
                    <textarea id="mensagem" rows="2" required></textarea>
                </p>

                <button type="submit" class="btn-enviar">Enviar Mensagem</button>
            </form>
        </article>

        <aside class="info-sidebar">
            <article class="card-info-laranja">
                <header>
                    <h2>Informação de contato</h2>
                    <p class="sidebar-intro">Dúvidas, sugestões, problemas com o site? <br>Entre em contato conosco!</p>
                </header>
                
                <address class="contact-details">
                    <p class="method-card card-laranja">
                        <i class="fa-solid fa-envelope" aria-hidden="true"></i>
                        <a href="mailto:hydriatcc@gmail.com">hydriatcc@gmail.com</a>
                    </p>
                    <p class="method-card card-azul">
                        <i class="fa-solid fa-users" aria-hidden="true"></i>
                        <span>Grupo 2 - INI3AM</span>
                    </p>
                </address>
            </article>
        </aside>

    </section>

    <aside class="bg-shape-blue" aria-hidden="true"></aside>
</main>

    

    <nav class="mobile-navigation" aria-label="Navegação inferior">
        <ul>
            <li>
                <a href="/">
                    <i class="fas fa-home" aria-hidden="true"></i>
                    <span>Início</span>
                </a>
            </li>
            <li>
                <a href="/projetos">
                    <i class="fas fa-file-alt" aria-hidden="true"></i>
                    <span>Projetos</span>
                </a>
            </li>
            <li>
                <a href="/contato">
                    <i class="fas fa-comment-dots" aria-hidden="true"></i>
                    <span>Contato</span>
                </a>
            </li>
            <li>
                <a href="/sobre">
                    <i class="fas fa-users" aria-hidden="true"></i>
                    <span>Sobre</span>
                </a>
            </li>
            <li>
                <a href="/auth/login">
                    <i class="fas fa-user" aria-hidden="true"></i>
                    <span>Perfil</span>
                </a>
            </li>
        </ul>
    </nav>
    <script src="/js/auto-fix.js"></script>
    <script>
        const contactForm = document.getElementById('contact-form');
        if (contactForm) {
            contactForm.addEventListener('submit', function (event) {
                event.preventDefault();
                window.location.href = '/mensagemEnviada/';
            });
        }
    </script>
    <%- include("../partial/footer") %>
